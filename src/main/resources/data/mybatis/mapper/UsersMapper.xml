<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="data.mybatis.mapper.UsersMapper">

	<resultMap type="com.spring.datetree.Security.CustomUserDetail" id="UserDetail">
		<id property="userid" column="userid"/>
		<result property="password" column="password"/>
		<result property="enabled" column="enabled"/>
		<collection property="authList" ofType="com.spring.datatree.Vo.Users_AuthorityVo">
			<result property="userid" column="userid"/>
			<result property="authority" column="authority"/>
		</collection>
	</resultMap>
	
	<select id="getAuths" parameterType="String" resultMap="UserDetail">
		select * from users u, users_authority ua
		where u.userid = ua.userid and ua.userid=#{userid}
	</select>
	
	<insert id="UserInsert" parameterType="com.spring.datatree.Vo.UsersVo">
		insert into users values(#{userid},#{pw},#{name},#{phone},sysdate,'1')
	</insert>
	
	<insert id="AuthInsert" parameterType="com.spring.datatree.Vo.Users_AuthorityVo">
		insert into users_authority values(#{userid},#{authority})
	</insert>
	
</mapper>