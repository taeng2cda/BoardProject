<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xmlns:sec="http://www.springframework.org/schema/security" 
	xsi:schemaLocation="http://www.springframework.org/schema/security http://www.springframework.org/schema/security/spring-security-5.2.xsd
		http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
	<!-- 네임스페이스 탭에 시큐리티 (체크)추가 -->
	
	
	<!-- 암호화 객체 -->
	<bean id="passwordEncoding" class="org.springframework.security.crypto.bcrypt.BCryptPasswordEncoder" />
	<bean id="customuserDetailService" class="com.spring.datatree.Security.CustomUserDetailService"/>
	<bean id="loginFailHandler" class="com.spring.datatree.LoginHandler.LoginFailHandler" />

	
	<!-- 요청에 따른 권한 설정 -->
	<sec:http auto-config="true" >
		<!-- 권한 설정 -->
		<sec:intercept-url pattern="/authority_user/**" access="hasRole('ROLE_MEMBER')"/>
		<sec:intercept-url pattern="/authority_admin/**" access="hasRole('ROLE_ADMIN')"/>
		<sec:intercept-url pattern="/**" access="permitAll"/>
		
		<!-- 로긴 페이지 설정 -->
		<sec:form-login login-page="/login" 
		username-parameter="userid" 
		password-parameter="pw" 
		authentication-failure-handler-ref="loginFailHandler"
		/>
			
		<!-- 로그아웃 설정  -->
		<sec:logout logout-url="/logout" 
		invalidate-session="true" 
		logout-success-url="/" 
		delete-cookies="true"
		/>
		<sec:form-login/>
	</sec:http>
	
	
	<!-- 인증매니져 설정 -->
	<sec:authentication-manager>
		<sec:authentication-provider user-service-ref="customuserDetailService">
			<sec:password-encoder ref="passwordEncoding"/>
		</sec:authentication-provider>
	</sec:authentication-manager>	
	
	
</beans>
